#!/usr/bin/make -f
export CARGO_HOME=$(CURDIR)/debian/.cargo
export HOME=$(CURDIR)/debian

%:
	dh $@

override_dh_auto_build:
	cargo build --release

override_dh_auto_install:
	install -Dm755 target/release/cpu-tweaks $(CURDIR)/debian/cpu-tweaks/usr/bin/cpu-tweaks
	install -Dm644 assets/cpu-tweaks.svg $(CURDIR)/debian/cpu-tweaks/usr/share/icons/hicolor/scalable/apps/cpu-tweaks.svg
	install -Dm644 assets/cpu-tweaks.desktop $(CURDIR)/debian/cpu-tweaks/usr/share/applications/cpu-tweaks.desktop
	install -Dm644 assets/com.github.ehnxnsm.cpu-tweaks.policy $(CURDIR)/debian/cpu-tweaks/usr/share/polkit-1/actions/com.github.ehnxnsm.cpu-tweaks.policy

override_dh_auto_test:
	# skip tests

override_dh_auto_clean:
	cargo clean || true
	rm -rf debian/.cargo
